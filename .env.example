# Copy to `.env` for local dev.
# Production URL lives in `.env.production` (used by `npm run build`).
# You can also set REACT_APP_API_BASE_URL on the Railway service (overrides at build time if you prefer).

# Backend base URL including /api — same host as orinket `NEXT_PUBLIC_API_URL` when sharing one API.
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Optional: legacy alias (resolveDashboardApiBase prefers REACT_APP_API_BASE_URL)
# REACT_APP_LOCAL_API_URL=http://localhost:5000/api

REACT_APP_GOOGLE_CLIENT_ID=

REACT_APP_SYSTEM_ADMIN_ROLE_ID=
REACT_APP_DEFAULT_USER_ID=
REACT_APP_DEFAULT_USER_EMAIL=
REACT_APP_ADMIN_PASSWORD=
